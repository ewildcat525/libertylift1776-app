# Supabase Configuration
# Get these from your Supabase project: Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Canonical site URL used for metadata, OG images, and the sitemap.
# Set this to your production domain when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email reminder pipeline (server-only; required in production) ---
# Service role key from Supabase: Settings -> API. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (https://resend.com) API key and verified sender.
RESEND_API_KEY=re_your_api_key
EMAIL_FROM="Liberty Lift 1776 <hello@yourdomain.com>"

# Shared secret protecting the cron route and signing unsubscribe links.
# Vercel sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=generate-a-long-random-string
